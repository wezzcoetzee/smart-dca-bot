{
  "name": "smart-dca-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted dollar-cost-averaging bot that buys spot BTC on Hyperliquid on a schedule, with SMA-based multipliers, a dashboard, and Discord notifications.",
  "license": "MIT",
  "author": "Wesley Coetzee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wezzcoetzee/smart-dca-bot.git"
  },
  "homepage": "https://github.com/wezzcoetzee/smart-dca-bot#readme",
  "bugs": {
    "url": "https://github.com/wezzcoetzee/smart-dca-bot/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "eslint",
    "cron": "bun run scripts/cron.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "./run-tests.sh",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "^0.32.2",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "openapi-types": "^12.1.3",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.6.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "swagger-ui-react": "^5.31.0",
    "tailwind-merge": "^3.4.0",
    "viem": "^2.47.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "latest",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/swagger-ui-react": "^5.18.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prisma": "^7.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint"
  }
}
