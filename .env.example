# ===========================================
# ENV-ONLY Configuration
# ===========================================
# These values MUST be set via environment variables.
# They cannot be configured through the Settings UI.

# Database connection string (required)
# Use this value when running the app on your host machine.
# Docker Compose overrides this inside containers to use host "db".
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_dca_bot

# Encryption key for sensitive DB fields (required, 32 bytes hex)
# Generate with: openssl rand -hex 32
DB_ENCRYPTION_KEY=

# Cron schedule expression (default: midnight and noon UTC)
CRON_EXPRESSION=0 0,12 * * *

# Runtime flags
TEST_MODE=false

# ===========================================
# Cron Script Configuration
# ===========================================
# These are used by the standalone cron script (scripts/cron.ts)
# to authenticate with the API endpoint.

# API URL for cron script to call
API_URL=http://localhost:3001

# Cron secret for API authentication (must match value in DB/Settings UI)
CRON_SECRET=your-random-secret-key-here
